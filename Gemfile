# Local preview of the GitHub Pages site.
#
#   bundle install
#   bundle exec jekyll serve
#   → open http://localhost:4000
#
# The github-pages gem pins Jekyll and every plugin to the exact
# versions GitHub Pages runs in production, so local matches live.

source "https://rubygems.org"

gem "github-pages", group: :jekyll_plugins

# Ruby 3.0+ no longer ships webrick, which `jekyll serve` needs.
gem "webrick"
